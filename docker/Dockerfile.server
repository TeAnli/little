FROM golang:1.22-alpine AS builder

RUN apk add --no-cache gcc musl-dev

WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o server ./cmd/server

FROM alpine:3.20

WORKDIR /app
COPY --from=builder /build/server .
COPY content/ ./content/

EXPOSE 8080
CMD ["./server"]
