# Copy this file to .env and adjust values for your environment.
# Docker Compose reads DB_PASSWORD and ADMIN_PASSWORD from this file when run from
# the repository root with: docker compose --env-file .env -f docker/docker-compose.yml up -d

# -----------------------------
# Docker / PostgreSQL
# -----------------------------

# Password for the PostgreSQL user named "little".
DB_PASSWORD=change-me

# -----------------------------
# Backend server
# -----------------------------

# Backend HTTP port when running the Go server directly.
# Docker Compose currently exposes the server on host port 8080.
SERVER_PORT=8080

# PostgreSQL connection string for running the backend directly on the host.
# For Docker Compose, docker/docker-compose.yml builds this from DB_PASSWORD.
DATABASE_URL=postgres://little:change-me@localhost:5432/little?sslmode=disable

# Admin login password. Change this before deploying.
ADMIN_PASSWORD=change-me

# -----------------------------
# Public site metadata
# -----------------------------

# Used by the backend RSS feed.
SITE_TITLE=Little Blog
SITE_AUTHOR=TeAnli
SITE_URL=http://localhost

# Frontend site text is configured in:
# app/frontend/src/config/site.ts
